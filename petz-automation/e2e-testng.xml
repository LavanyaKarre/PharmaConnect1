<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  PETZ end-to-end story suite.

  Unlike the default umbrella (testng.xml) and functional-testng.xml — both of
  which discover tests by <package>, leaving cross-class execution order at the
  mercy of class-discovery — this suite uses an explicit ordered <classes> list
  so the run mirrors a real user journey end-to-end:

    Anonymous discovery
       └── Returning-user login
            └── New-user registration
                 └── Pet Owner journey
                      ├── Dashboard
                      ├── Browse Animals → Pet Detail → My Applications
                      ├── Book Appointment → My Appointments
                      ├── Rescue List → Report Animal
                      └── Notifications
       └── NGO operator journey
            ├── Dashboard → My Animals → Applications → Rescue Queue
       └── Hospital operator journey
            ├── Dashboard → Doctors
       └── Cross-role security guards
       └── Cross-cutting glue (header / sidebar / sign-out / reload)
       └── API contract checks (REST Assured, independent of UI)

  preserve-order="true" on each <test> forces TestNG to honour the listed
  class order (and within each class, @Test priority still orders methods).

  Run with:
    mvn test -DsuiteXmlFile=e2e-testng.xml

  Group filters from the pom still apply, so you can carve out a slice of the
  full story without losing the order:
    mvn test -DsuiteXmlFile=e2e-testng.xml -Dgroups=smoke
    mvn test -DsuiteXmlFile=e2e-testng.xml -Dgroups=ui      <- layout-only walk-through
    mvn test -DsuiteXmlFile=e2e-testng.xml -Dgroups=functional
-->
<suite name="PETZ End-to-End Story Suite" verbose="1" parallel="false">

    <listeners>
        <listener class-name="com.cts.mfrp.petz.utils.TestListener"/>
    </listeners>

    <!-- ─── Stage 1 — Anonymous visitor discovers the platform ─── -->
    <test name="1. Anonymous Discovery (TC001-TC005)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.LandingPageTest"/>
        </classes>
    </test>

    <!-- ─── Stage 2 — Returning user signs in ─── -->
    <test name="2. Login Flow (TC006-TC012)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.LoginPageTest"/>
        </classes>
    </test>

    <!-- ─── Stage 3 — New user signs up (all 3 roles) ─── -->
    <test name="3. Registration Flow (TC013-TC020)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.RegisterPageTest"/>
        </classes>
    </test>

    <!-- ─── Stage 4 — Pet Owner journey ─── -->
    <test name="4a. Pet Owner — Dashboard (TC021-TC025)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.PetOwnerDashboardTest"/>
        </classes>
    </test>

    <test name="4b. Pet Owner — Browse → Apply for Adoption (TC026-TC037)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.BrowseAnimalsTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.PetDetailTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.MyApplicationsTest"/>
        </classes>
    </test>

    <test name="4c. Pet Owner — Book a Vet Appointment (TC038-TC046)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.BookAppointmentTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.MyAppointmentsTest"/>
        </classes>
    </test>

    <test name="4d. Pet Owner — Report a Rescue (TC047-TC056)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.RescueListTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.ReportAnimalTest"/>
        </classes>
    </test>

    <test name="4e. Pet Owner — Notifications (TC057-TC058)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.NotificationsTest"/>
        </classes>
    </test>

    <!-- ─── Stage 5 — NGO operator journey ─── -->
    <test name="5. NGO Operator Journey (TC059-TC069)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.NGODashboardTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.NGOMyAnimalsTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.NGOApplicationsTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.NGORescueQueueTest"/>
        </classes>
    </test>

    <!-- ─── Stage 6 — Hospital operator journey ─── -->
    <test name="6. Hospital Operator Journey (TC070-TC079)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.HospitalDashboardTest"/>
            <class name="com.cts.mfrp.petz.tests.functional.HospitalDoctorsTest"/>
        </classes>
    </test>

    <!-- ─── Stage 7 — Cross-role security: each role tries forbidden routes ─── -->
    <test name="7. Cross-Role Security Guards (TC080-TC084)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.RoleBasedAccessTest"/>
        </classes>
    </test>

    <!-- ─── Stage 8 — Cross-cutting glue: header / sidebar / sign-out / reload ─── -->
    <test name="8. Cross-Cutting Glue (TC085-TC090)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.functional.CrossCuttingTest"/>
        </classes>
    </test>

    <!-- ─── Stage 9 — API contract validation (independent of UI flow) ─── -->
    <test name="9. API Contract Checks (TC101-TC1101)" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.api.TC101_AuthLoginTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC102_AuthRegisterTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC201_UserProfileTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC301_PetsTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC401_HospitalsPublicTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC402_HospitalsRoleTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC501_AppointmentsTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC601_RescueTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC701_AdoptionPublicTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC702_AdoptionNgoTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC801_NgoTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC901_NotificationsTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC1001_AdminTest"/>
            <class name="com.cts.mfrp.petz.tests.api.TC1101_AuthBoundariesTest"/>
        </classes>
    </test>

</suite>
