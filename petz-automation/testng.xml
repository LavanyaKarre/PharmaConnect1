<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Default umbrella suite. Surefire is wired to this file in pom.xml.

  Runs the Functional (UI) suite followed by the API suite in one shot.
  If you only want one of them, use the dedicated files directly:
    mvn test -DsuiteXmlFile=functional-testng.xml
    mvn test -DsuiteXmlFile=api-testng.xml

  Group filtering works here too (wired through surefire <groups> in pom.xml):
    mvn test -Dgroups=smoke              <- runs all smoke tests across UI + API
    mvn test -Dgroups=regression         <- runs everything (default)
    mvn test -Dgroups=sanity,negative    <- multiple tags
-->
<suite name="PETZ Full Suite (Functional + API)" verbose="1" parallel="false">

    <listeners>
        <listener class-name="com.cts.mfrp.petz.utils.TestListener"/>
    </listeners>

    <test name="Functional (UI) tests">
        <packages>
            <package name="com.cts.mfrp.petz.tests.functional"/>
        </packages>
    </test>

    <test name="API tests (REST Assured)">
        <packages>
            <package name="com.cts.mfrp.petz.tests.api"/>
        </packages>
    </test>

</suite>
