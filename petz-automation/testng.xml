<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  PETZ Automation - 15 TCs as an end-to-end narrative.

  Four classes execute in fixed order (preserve-order=true). Each role logs in
  once at @BeforeClass and shares one browser session across its TCs:

    1. PublicJourneyTest    (TC01-TC02)  anonymous: landing render + register
    2. PetOwnerJourneyTest  (TC03-TC09)  one PetOwner login: dashboard + add pet + book appt + report rescue + browse/apply adoption + verify reservations
    3. NGOJourneyTest       (TC10-TC12)  one NGO login: dashboard + add animal + review applications
    4. HospitalJourneyTest  (TC13-TC15)  one Hospital login: dashboard + add doctor + confirm appointment

  Run:
    mvn test                        - visible browser (default), all 15 TCs
    mvn test -Dheadless=true        - headless mode for CI
-->
<suite name="PETZ E2E Suite" verbose="1">

    <listeners>
        <listener class-name="com.cts.mfrp.petz.listeners.TestListener"/>
    </listeners>

    <test name="PETZ E2E Flow" preserve-order="true">
        <classes>
            <class name="com.cts.mfrp.petz.tests.PublicJourneyTest"/>
            <class name="com.cts.mfrp.petz.tests.PetOwnerJourneyTest"/>
            <class name="com.cts.mfrp.petz.tests.NGOJourneyTest"/>
            <class name="com.cts.mfrp.petz.tests.HospitalJourneyTest"/>
        </classes>
    </test>

</suite>
