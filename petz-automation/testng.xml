<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  PETZ Automation - Selenium 4 + TestNG suite
  30 test classes auto-discovered by package, one TC per class.
  TestListener wires ExtentReports (HTML at test-output/reports/ExtentReport.html).

  Run:
    mvn test                                  - all 30 TCs
    mvn test -Dgroups=smoke                   - 5 smoke TCs
    mvn test -Dgroups=auth                    - auth module only
    mvn test -Dgroups=monkey                  - data sets that include Monkey rows
-->
<suite name="PETZ Automation Suite" verbose="1">

    <listeners>
        <listener class-name="com.cts.mfrp.petz.listeners.TestListener"/>
    </listeners>

    <test name="PETZ - 30 Test Cases">
        <packages>
            <package name="com.cts.mfrp.petz.tests.landing"/>
            <package name="com.cts.mfrp.petz.tests.authentication"/>
            <package name="com.cts.mfrp.petz.tests.user"/>
            <package name="com.cts.mfrp.petz.tests.ngo"/>
            <package name="com.cts.mfrp.petz.tests.hospital"/>
        </packages>
    </test>

</suite>
