<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  PETZ Functional (UI) Suite.

  Runs every Selenium / UI test in the project. The default invocation
  ("mvn test -DsuiteXmlFile=functional-testng.xml") runs everything;
  pass -Dgroups=<tag> to filter by:
    smoke       - minimum critical-path render checks (~9 tests, < 2 min)
    sanity      - smoke + common happy paths (~30 tests, ~10 min)
    regression  - every functional test (default)
    positive    - happy-path tests only
    negative    - disabled-state / required-field / guard tests
    functional  - every UI test (alias for regression here)

  Tags can be combined (OR semantics):
    mvn test -DsuiteXmlFile=functional-testng.xml -Dgroups=smoke,sanity

  You can also filter by scenario tag (preserved from the previous suite):
    mvn test -DsuiteXmlFile=functional-testng.xml -Dgroups=landingPage
-->
<suite name="PETZ Functional Suite" verbose="1" parallel="false">

    <listeners>
        <listener class-name="com.cts.mfrp.petz.utils.TestListener"/>
    </listeners>

    <test name="Functional - all UI scenarios">
        <packages>
            <package name="com.cts.mfrp.petz.tests.functional"/>
        </packages>
    </test>

</suite>
