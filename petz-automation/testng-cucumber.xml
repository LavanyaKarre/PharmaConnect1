<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Cucumber BDD suite — selected by the "cucumber" Maven profile
  (mvn verify -Pcucumber sets suiteXmlFile=testng-cucumber.xml).

  It runs a single class, RunCucumberTest, which extends
  AbstractTestNGCucumberTests and executes every .feature on the classpath.
  No TestListener here — the Cucumber plugins produce the report instead.
-->
<suite name="PETZ Cucumber Suite" verbose="1">
    <test name="PETZ BDD Flow">
        <classes>
            <class name="com.cts.mfrp.petz.cucumber.runner.RunCucumberTest"/>
        </classes>
    </test>
</suite>
