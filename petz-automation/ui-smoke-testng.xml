<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="PETZ UI Smoke Suite (new scenarios)" verbose="1" parallel="false">
    <test name="Hospital Dashboard">
        <groups><run><include name="hospitalDashboard"/></run></groups>
        <classes><class name="com.cts.mfrp.petz.tests.HospitalDashboardTest"/></classes>
    </test>
    <test name="Hospital Doctors">
        <groups><run><include name="hospitalDoctors"/></run></groups>
        <classes><class name="com.cts.mfrp.petz.tests.HospitalDoctorsTest"/></classes>
    </test>
    <test name="Cross-Cutting">
        <groups><run><include name="crossCutting"/></run></groups>
        <classes><class name="com.cts.mfrp.petz.tests.CrossCuttingTest"/></classes>
    </test>
</suite>
