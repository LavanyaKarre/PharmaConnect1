<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="PETZ UI Suite" verbose="1" parallel="false">

    <test name="Pet Owner Dashboard Scenario (TC021 to TC025)">
        <classes>
            <class name="com.cts.mfrp.petz.tests.PetOwnerDashboardTest"/>
        </classes>
    </test>

    <test name="Notifications Scenario (TC057 to TC058)">
        <groups>
            <run>
                <include name="notifications"/>
            </run>
        </groups>
        <classes>
            <class name="com.cts.mfrp.petz.tests.NotificationsTest"/>
        </classes>
    </test>

</suite>
