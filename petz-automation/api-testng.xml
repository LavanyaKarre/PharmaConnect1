<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  PETZ API Suite (REST Assured).

  Runs every TC101 - TC1101 API test in the project. Default invocation
  runs all of them; pass -Dgroups=<tag> to filter:
    smoke       - login, profile, pets-crud, hospitals-public seeded
    sanity      - smoke + the first happy-path test in every TC class
    regression  - every API test (default)
    positive / negative - by intent

  Or filter by module scenario tag:
    mvn test -DsuiteXmlFile=api-testng.xml -Dgroups=pets,appointments
-->
<suite name="PETZ API Suite" verbose="1" parallel="false">

    <listeners>
        <listener class-name="com.cts.mfrp.petz.utils.TestListener"/>
    </listeners>

    <test name="API - all TC101 to TC1101">
        <packages>
            <package name="com.cts.mfrp.petz.tests.api"/>
        </packages>
    </test>

</suite>
