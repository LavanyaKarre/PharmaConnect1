<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fixture for TC101_AuthLoginTest. One <case> per existing @Test method;
  each method fetches its own row by id via LoginCases.byId(...).

  Schema (id is required; everything else is per-case optional):
    - id                : key the @Test method looks up (TC101_1 .. TC101_4)
    - description       : mirrors the @Test description, kept for Extent context

    - rawBody           : raw request body posted via AuthClient.loginRaw(...).
                          Used by TC101_1 (empty JSON) and TC101_4 (malformed
                          JSON). When present, the test calls loginRaw; when
                          absent, the test calls login(email,password) below.
    - email             : input email for the LoginRequest body (TC101_2 / _3).
    - password          : input password for the LoginRequest body (TC101_2 / _3).
                          NB: these are TEST INPUTS sent to the backend, not
                          credentials to authenticate AS — XML must never hold a
                          credential meant to log a real seeded user in. For
                          unknown-user cases, use a clearly-throwaway string
                          (TC101_3 generates randomEmail in code instead — see
                          'email' field there).
    - randomEmailPrefix : when set, the test generates a fresh email
                          {prefix}_{millis}@example.com at runtime (TC101_3
                          uses this to guarantee a non-existent user). Mutually
                          exclusive with <email>.

    - expectedStatus    : HTTP status the backend is expected to return.
    - expectedSuccess   : optional Boolean — value of response.success.
    - expectedMessage   : optional — exact value of response.message.
    - expectedFields    : optional list of <field name="..."> entries that must
                          appear under response.data with the given text.

  No new test cases are added by editing this file — rows are 1:1 with the
  existing @Test methods in TC101_AuthLoginTest.
-->
<loginCases>

    <case>
        <id>TC101_1</id>
        <description>login with empty body returns 400 with validation map</description>
        <rawBody>{}</rawBody>
        <expectedStatus>400</expectedStatus>
        <expectedSuccess>false</expectedSuccess>
        <expectedFields>
            <field name="email">must not be blank</field>
            <field name="password">must not be blank</field>
        </expectedFields>
    </case>

    <case>
        <id>TC101_2</id>
        <description>login with invalid email format returns 400</description>
        <email>not-an-email</email>
        <password>AnyPass1</password>
        <expectedStatus>400</expectedStatus>
        <expectedFields>
            <field name="email">must be a well-formed email address</field>
        </expectedFields>
    </case>

    <case>
        <id>TC101_3</id>
        <description>login with non-existent user returns 404</description>
        <randomEmailPrefix>nobody</randomEmailPrefix>
        <password>AnyPass1</password>
        <expectedStatus>404</expectedStatus>
        <expectedSuccess>false</expectedSuccess>
        <expectedMessage>User not found.</expectedMessage>
    </case>

    <case>
        <id>TC101_4</id>
        <description>login with malformed JSON returns 500 (deployed-bug behaviour — flip to 400 when backend fixes it)</description>
        <rawBody>not valid json</rawBody>
        <expectedStatus>500</expectedStatus>
    </case>

</loginCases>
