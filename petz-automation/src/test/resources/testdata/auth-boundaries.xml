<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fixture for TC1101_AuthBoundariesTest. One <case> per existing @Test method;
  the test method looks up its own row by id via AuthBoundaryCases.byId(...).

  Schema (all fields optional except id, description, expectedStatus):
    - id              : exact key used by the test method (TC1101_1 / _2 / _3)
    - description     : mirrors the @Test description (for reference / Extent context)
    - token           : literal Bearer token sent on the request (only TC1101_2)
    - endpoint        : request path (only TC1101_3 — others use ApiEndpoints.USERS_ME)
    - expectedStatus  : HTTP status the backend is expected to return
    - expectedMessage : exact value of response.data.message (only TC1101_3)

  No new test cases are added by editing this file — rows are 1:1 with the
  existing @Test methods.
-->
<authBoundaryCases>

    <case>
        <id>TC1101_1</id>
        <description>no Bearer token on protected endpoint returns 403 with empty body</description>
        <expectedStatus>403</expectedStatus>
    </case>

    <case>
        <id>TC1101_2</id>
        <description>garbage Bearer token returns 403 with empty body</description>
        <token>not-a-real-jwt</token>
        <expectedStatus>403</expectedStatus>
    </case>

    <case>
        <id>TC1101_3</id>
        <description>role mismatch returns 403 with 'Access denied.' message</description>
        <endpoint>/admin/users</endpoint>
        <expectedStatus>403</expectedStatus>
        <expectedMessage>Access denied.</expectedMessage>
    </case>

</authBoundaryCases>
