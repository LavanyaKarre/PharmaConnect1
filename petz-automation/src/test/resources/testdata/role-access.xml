<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fixture for RoleBasedAccessTest. One <case> per existing @Test method;
  the method looks up its own row by id via RoleAccessCases.byId(...).

  Schema (id, loginAs, expectedRedirectFragment, and at least one <route>
  are required; expectedSidebarRole is optional):
    - id                       : exact key used by the @Test method (TC080 .. TC084)
    - description              : mirrors the @Test description (for Extent context)
    - loginAs                  : role key resolved at runtime against AppConstants
                                 credentials. Allowed values:
                                   NONE       — anonymous (no login)
                                   PET_OWNER  — LoginPage.loginAsPetOwner()
                                   NGO        — LoginPage.loginAsNgo()
                                   HOSPITAL   — LoginPage.loginAsHospital()
                                 XML never stores literal emails / passwords; the
                                 test method calls the right loginAs* helper.
    - blockedRoutes            : list of relative paths the role should be
                                 redirected away from. Convention: relative only
                                 (e.g. '/ngo/animals'). The test composes with
                                 AppConstants.BASE_URL at runtime — never paste
                                 a full URL here.
    - expectedRedirectFragment : substring the final URL must contain
                                 (e.g. '/auth/login', '/dashboard'). Relative.
    - expectedSidebarRole      : optional — when present, the test additionally
                                 asserts SidebarComponent.getRoleLabel() equals
                                 this value (only TC081 currently uses this).

  No new test cases are added by editing this file. Rows are 1:1 with the
  existing @Test methods in RoleBasedAccessTest.
-->
<roleAccessCases>

    <case>
        <id>TC080</id>
        <description>Anonymous user is sent to /auth/login on every guarded route</description>
        <loginAs>NONE</loginAs>
        <blockedRoutes>
            <route>/dashboard</route>
            <route>/ngo</route>
            <route>/hospital</route>
            <route>/appointments</route>
            <route>/rescue/report</route>
        </blockedRoutes>
        <expectedRedirectFragment>/auth/login</expectedRedirectFragment>
    </case>

    <case>
        <id>TC081</id>
        <description>Pet Owner cannot enter NGO routes (redirect to /dashboard)</description>
        <loginAs>PET_OWNER</loginAs>
        <blockedRoutes>
            <route>/ngo</route>
            <route>/ngo/animals</route>
            <route>/ngo/applications</route>
            <route>/ngo/rescues</route>
        </blockedRoutes>
        <expectedRedirectFragment>/dashboard</expectedRedirectFragment>
        <expectedSidebarRole>USER</expectedSidebarRole>
    </case>

    <case>
        <id>TC082</id>
        <description>Pet Owner cannot enter Hospital routes (redirect to /dashboard)</description>
        <loginAs>PET_OWNER</loginAs>
        <blockedRoutes>
            <route>/hospital</route>
            <route>/hospital/appointments</route>
            <route>/hospital/doctors</route>
        </blockedRoutes>
        <expectedRedirectFragment>/dashboard</expectedRedirectFragment>
    </case>

    <case>
        <id>TC083</id>
        <description>NGO user cannot enter Hospital routes (app sends every cross-role attempt to /dashboard, not /ngo as the spec describes)</description>
        <loginAs>NGO</loginAs>
        <blockedRoutes>
            <route>/hospital</route>
            <route>/hospital/appointments</route>
            <route>/hospital/doctors</route>
        </blockedRoutes>
        <expectedRedirectFragment>/dashboard</expectedRedirectFragment>
    </case>

    <case>
        <id>TC084</id>
        <description>Hospital user cannot enter NGO routes (app's guard sends to /dashboard, not /hospital as the spec describes)</description>
        <loginAs>HOSPITAL</loginAs>
        <blockedRoutes>
            <route>/ngo</route>
            <route>/ngo/animals</route>
            <route>/ngo/applications</route>
            <route>/ngo/rescues</route>
        </blockedRoutes>
        <expectedRedirectFragment>/dashboard</expectedRedirectFragment>
    </case>

</roleAccessCases>
