<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for the test suite.

  Console: human-readable, level filtered to INFO by default.
  File:    full DEBUG capture into test-output/logs/petz-automation.log,
           rolled per run (overwritten — keeps disk usage flat).

  Override level from the command line:
    mvn test -Dlog.level=DEBUG
    mvn test -Dlog.level=WARN
-->
<configuration>

    <property name="LOG_DIR"   value="test-output/logs"/>
    <property name="LOG_FILE"  value="${LOG_DIR}/petz-automation.log"/>
    <property name="LOG_LEVEL" value="${log.level:-INFO}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_FILE}</file>
        <append>false</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Quiet noisy third-party loggers -->
    <logger name="org.apache"               level="WARN"/>
    <logger name="io.netty"                 level="WARN"/>
    <logger name="org.openqa.selenium"      level="WARN"/>
    <logger name="io.github.bonigarcia"     level="WARN"/>
    <logger name="org.testng"               level="WARN"/>

    <!-- Project loggers: honour -Dlog.level override -->
    <logger name="com.cts.mfrp.petz"        level="${LOG_LEVEL}"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
